# ==========================================
# 1. 환경 변수 및 비밀 정보 (보안 필수!)
# ==========================================
# API 키나 비밀번호가 들어있는 파일은 절대 깃허브에 올리면 안 됩니다.
.env
.env.*

# ==========================================
# 2. 파이썬(Python) 임시 및 캐시 파일
# ==========================================
# 파이썬 코드가 실행되면서 자동 생성되는 찌꺼기 파일들입니다.
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# 가상환경 폴더 (각자 컴퓨터에서 새로 만들어야 함)
venv/
.venv/
env/

# ==========================================
# 3. 대용량 AI 모델 파일 및 데이터
# ==========================================
# 깃허브 용량 제한(100MB)을 방지하기 위해 무거운 AI 모델은 제외합니다.
*.pt
*.pth
*.onnx

# ==========================================
# 4. 실행 파일 및 운영체제 임시 파일
# ==========================================
# 실행 프로그램이나 윈도우/맥이 자동으로 만드는 시스템 파일입니다.
*.exe
.DS_Store
Thumbs.db

# ==========================================
# 5. 에디터 및 에이전트 설정 파일
# ==========================================
# 개인적인 작업 도구 설정 폴더입니다.
.agents/
.vscode/
.idea/
